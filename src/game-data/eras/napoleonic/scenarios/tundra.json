  "locales": {
    "en": {
      "name": "Tundra",
      "description": "Winter in the flood plain of Polesia. Open snowfields and frozen rivers and lakes provide little succour for weary troops. Quel massacre! Et sans résultat!"
    },
    "ru": {
      "name": "Тундра",
      "description": "Зима в пойме Полесья. Открытые снежные поля, замерзшие реки и озера не дают покоя утомленным войскам. Какое побоище! И без результата!"
    },
    "es": {
      "name": "Tundra",
      "description": "Invierno en la llanura aluvial de Polesia. Los campos nevados abiertos y los ríos y lagos helados brindan poco consuelo a las tropas fatigadas. ¡Qué masacre! ¡Y sin resultado!"
    },
    "de": {
      "name": "Tundra",
      "description": "Winter in der Überschwemmungsebene von Polesia. Offene Schneefelder und gefrorene Flüsse und Seen bieten den müden Truppen wenig Trost. Was für ein Gemetzel! Und ohne Ergebnis!"
    },
    "fr": {
      "name": "Toundra",
      "description": "L'hiver dans la plaine inondable de la Polésie. Les champs de neige ouverts et les rivières et lacs gelés n'apportent que peu de réconfort aux troupes lassées. Quel massacre ! Et sans résultat !"
    },
    "it": {
      "name": "Tundra",
      "description": "L'inverno nella pianura alluvionale della Polesia. I campi di neve aperti e i fiumi e i laghi ghiacciati offrono poco sollievo alle truppe stanche. Quel massacro! E senza risultato!"
    },
    "pl": {
      "name": "Tundra",
      "description": "Zima na terenach zalewowych Polesia. Otwarte polach śnieżne oraz zamarznięte rzeki i jeziora dają zmęczonym wojskom niewiele wytchnienia. Co za masakra! I bez rezultatu!"
    },
    "ar": {
      "name": "تندرا",
      "description": "الشتاء في السهول الفيضية في بوليسيا. توفر حقول الثلوج المفتوحة والأنهار والبحيرة المتجمدة القليل من المساعدة للقوات المتعبة. يا له من مجزرة! وبدون نتيجة!"
    },
    "el": {
      "name": "Τούντρα",
      "description": "Χειμώνας στην πλημμυρική πεδιάδα της Πολέσιας. Τα ανοιχτά χιονισμένα πεδία και τα παγωμένα ποτάμια και λίμνες προσφέρουν ελάχιστη ανακούφιση στα κουρασμένα στρατεύματα. Τι σφαγή! Και χωρίς αποτέλεσμα!"
    },
    "hi": {
      "name": "टुंड्रा",
      "description": "पोलिसिया के बाढ़ के मैदान में सर्दी । खुले बर्फबारी और जमी हुई नदियों और झीलों थके हुए सैनिकों के लिए थोड़ा सहारा प्रदान करते हैं । क्या नरसंहार! और बिना परिणाम के!"
    },
    "hu": {
      "name": "Tundra",
      "description": "Tél Poleszje ártéri síkságán. A nyílt hófödte mezők, a befagyott folyók és tavak nem sok enyhülést nyújtanak a fáradt csapatoknak. Micsoda mészárlás! És eredmény nélkül!"
    },
    "id": {
      "name": "Tundra",
      "description": "Musim dingin di dataran banjir Polesia. Padang salju yang terbuka serta sungai dan danau yang membeku memberikan sedikit pertolongan bagi pasukan yang lelah. Pembantaian yang luar biasa! Dan tanpa hasil!"
    },
    "ja": {
      "name": "ツンドラ",
      "description": "ポレシアの氾濫原の冬。開いた雪原と凍った川や湖は、疲れた軍隊にほとんど救いを与えません。なんて虐殺なんだ！そして何の結果も得られない！"
    },
    "kr": {
      "name": "툰드라",
      "description": "Polesia의 홍수 평야의 겨울. 열린 설원과 얼어 붙은 강과 호수는 지친 군대에게 거의 도움을주지 않습니다. 참으로 대학살이다! 그리고 아무 결과도 없다!"
    },
    "pt": {
      "name": "Tundra",
      "description": "O inverno na planície aluvial da Polésia. Os campos de neve abertos e os rios e lagos gelados oferecem pouco alívio para as tropas cansadas. Que massacre! E sem resultado!"
    },
    "tr": {
      "name": "Tundra",
      "description": "Polesia sel ovasında kış. Açık kar alanları ve donmuş nehirler ile göller yorgun birliklere çok az yardım sağlar. Ne katliam ama! Ve sonuçsuz!"
    },
    "uk": {
      "name": "Тундра",
      "description": "Зима в заплаві Полісся. Відкриті снігові поля та замерзлі річки й озера дають мало спокою втомленим військам. Яке побоїще! І без результату!"
    },
    "vi": {
      "name": "Tundra",
      "description": "Mùa đông ở vùng ngập mặn của Polesia. Những cánh đồng tuyết rộng lớn và sông hồ đóng băng cung cấp rất ít sự hỗ trợ cho quân đội mệt mỏi. Một cuộc thảm sát thật sự! Và không có kết quả!"
    },
    "zh": {
      "name": "苔原",
      "description": "波列西亚平原的冬天。开阔的雪地、冰封的河流和湖泊为疲惫不堪的部队提供的救援微乎其微。多么惨烈的屠杀！而且毫无结果！"
    }
  }
}
